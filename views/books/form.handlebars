<h1>Books</h1>
<ul>
 {{#each books}}
   <li>{{this.title}} {{this.publishingYear}}</li>
 {{/each}}
</ul>

<form action="/books/create" role="form" method="post">
  <div>
    <label for="title">Title</label>
    <input type="text" id="title" name="Title">
  </div>
  <div>
    <label for="yearPublished">Year Published</label>
    <input type="text" id="yearPublished" name="yearPublished">
  </div>
  <button type="submit" class="btn btn-primary">Submit</button>
</form>